{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "excludeFiles": "{node_modules/{lucide-react,typescript,@img,@esbuild,@babel,web-streams-polyfill,rxjs,tailwindcss,tailwindcss-animate,rollup,@rollup,react-dom,caniuse-lite,react-router,@types,vite,@vitejs,framer-motion,terser,jiti,sucrase,csstype,motion-dom,@jridgewell,source-map,sharp,concurrently,acorn,nodemon,react,react-simple-maps,cobe,prop-types,react-helmet-async,postcss,autoprefixer,eslint*,@eslint*}/**,dist/**,src/**,public/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}